{
  "name": "@storytree/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "storytree core: the work-hierarchy schema (story / capability / contract) and the corpus validator. ADR-0002 / 0010 / 0013 / 0039.",
  "exports": {
    ".": "./src/index.ts",
    "./presence": "./src/presence.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "validate": "tsx scripts/validate-corpus.ts",
    "test": "tsx scripts/validate-corpus.ts && node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@storytree/verdict-contract": "workspace:*",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "~5.7.3"
  }
}
