{
  "name": "@storytree/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "storytree core: the work-hierarchy schema (story / capability / contract) and the corpus loader + validator. ADR-0002 / 0010 / 0013.",
  "exports": {
    ".": "./src/index.ts",
    "./sources": "./src/knowledge-sources.ts",
    "./knowledge": "./src/knowledge.ts",
    "./knowledge-render": "./src/knowledge-render.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "validate": "tsx scripts/validate-corpus.ts",
    "test": "tsx scripts/validate-corpus.ts && node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "~5.7.3"
  }
}
