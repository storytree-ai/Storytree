{
  "name": "@storytree/orchestrator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "storytree orchestration spine (ADR-0005): the deterministic step machine (runSequence / runLoop) that owns control flow while the owned loop judges at the leaf. Hosts the ADR-0020 red-green phase machine.",
