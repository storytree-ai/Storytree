{
  "name": "@storytree/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "storytree CLI (ADR-0023): the agent's exploratory, just-in-time interface to the Library. Choose-your-own-adventure — every command emits a result + doctrine + next envelope.",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "storytree": "./src/main.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "storytree": "tsx src/main.ts"
  },
  "dependencies": {
    "@storytree/core": "workspace:*",
    "@storytree/orchestrator": "workspace:*",
    "@storytree/store": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "~5.7.3"
  }
}
