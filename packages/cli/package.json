{
  "name": "@storytree/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "storytree CLI (ADR-0023): the agent's exploratory, just-in-time interface to the Library. Choose-your-own-adventure — every command emits a result + doctrine + next envelope.",
  "exports": {
    ".": "./src/index.ts",
    "./build": "./src/build.ts",
    "./secrets": "./src/secrets.ts"
  },
  "bin": {
    "storytree": "./src/main.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsx scripts/validate-corpus.ts && node --import tsx --test \"src/**/*.test.ts\"",
    "storytree": "tsx src/main.ts",
    "db": "tsx src/db-cli.ts"
  },
  "dependencies": {
    "@storytree/agent": "workspace:*",
    "@storytree/storage-protocol": "workspace:*",
    "@storytree/library": "workspace:*",
    "@storytree/notice-board": "workspace:*",
    "@storytree/orchestrator": "workspace:*",
    "@storytree/proof-protocol": "workspace:*",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "~5.7.3"
  }
}
