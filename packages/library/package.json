{
  "name": "@storytree/library",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The library organism (ADR-0068 step 3): the work-hierarchy schema (story / capability / contract) as schema-validated versioned documents. Pure zod, browser-safe, no node: imports in the main entry. ADR-0002 / 0010 / 0013.",
  "exports": {
    ".": "./src/index.ts",
    "./sources": "./src/knowledge-sources.ts",
    "./knowledge": "./src/knowledge.ts",
    "./knowledge-render": "./src/knowledge-render.ts",
    "./store": "./src/store/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@google-cloud/cloud-sql-connector": "^1.4.0",
    "@storytree/base": "workspace:*",
    "@storytree/verdict-contract": "workspace:*",
    "google-auth-library": "^10.7.0",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "~5.7.3"
  }
}
