{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/remote-session-setup.sh",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "bash -c 't=\"$(git rev-parse --show-toplevel 2>/dev/null)\" && node \"$t/packages/cli/worktree-health.mjs\" --hook || true'",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "node packages/cli/provision-worktree.mjs --hook",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "bash scripts/presence-hook.sh start",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "bash scripts/worktree-prune-hook.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node packages/cli/definition-injection.mjs",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash scripts/presence-hook.sh statusline"
  }
}
