{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/remote-session-setup.sh",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "bash scripts/presence-hook.sh start",
            "timeout": 20
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/presence-hook.sh end",
            "timeout": 20
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash scripts/presence-hook.sh statusline"
  }
}
