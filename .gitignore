# Dependencies
node_modules/
.pnp.*
.yarn/*

# Build output
dist/
build/
# ...except the desktop app's own icon asset (a committed source file, not a build artifact):
# re-include the dir (so git will traverse it) then the icon itself.
!apps/desktop/build/
!apps/desktop/build/icon.ico
out/
*.tsbuildinfo
.turbo/
.vite/

# Env / secrets
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Test / coverage
coverage/
.nyc_output/
# Playwright run artifacts (apps/studio UAT)
test-results/
playwright-report/

# Deferred / not produced today: DBOS is deferred (ADR-0019) and the store is
# keyless Cloud SQL (ADR-0021), so neither dir is generated now — kept ignored
# pre-emptively in case a future local-DBOS or local-Postgres path returns.
.dbos/
pgdata/

# Members (ADR-0043) are app-owned runtime state, not seed: the offline JSON
# backend writes apps/studio/data/users.json on the fly (the live source of truth is the
# events."user" projection in Cloud SQL). Never committed.
apps/studio/data/users.json

# Per-UAT-test attestations (ADR-0044) are app-owned runtime state too: the offline JSON backend
# writes apps/studio/data/attestations.json on the fly (the live source is events.attestation in
# Cloud SQL). Never committed.
apps/studio/data/attestations.json

# The offline JSON backend's assets store (ADR-0210) is app-owned runtime state: seeded on first
# read by deriving the corpus from knowledge.json + the library templates, then written here as the
# offline read/write store (the live source is the events library tables in Cloud SQL). This
# REPLACED the committed, generated apps/studio/data/assets.json, which was retired. Never committed.
apps/studio/data/assets.runtime.json

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
