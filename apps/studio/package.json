{
  "name": "studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "storytree studio — foundation forum UI (docs, inline comments, guidance library). No PixiJS / story-tree yet.",
  "scripts": {
    "dev": "node --import tsx node_modules/vite/bin/vite.js",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.4",
    "@storytree/core": "workspace:*",
    "@storytree/orchestrator": "workspace:*",
    "@storytree/store": "workspace:*",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.2",
    "typescript": "~5.7.3",
    "vite": "^6.0.7"
  }
}
