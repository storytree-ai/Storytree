{
  "name": "studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "storytree studio — forum UI (docs, inline comments, guidance library) + the story world at #/tree (SVG hex map of the work hierarchy, ADR-0036).",
  "scripts": {
    "dev": "node --import tsx node_modules/vite/bin/vite.js",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "node --import tsx server/serve.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "uat": "playwright test"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.4",
    "@storytree/drive": "workspace:*",
    "@storytree/forest-world": "workspace:*",
    "@storytree/library": "workspace:*",
    "@storytree/notice-board": "workspace:*",
    "@storytree/orchestrator": "workspace:*",
    "@storytree/studio-members": "workspace:*",
    "@storytree/proof-protocol": "workspace:*",
    "@xterm/addon-clipboard": "0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "mermaid": "11.15.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.7",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.7.3",
    "vite": "^6.0.7",
    "vitest": "^3.0.0"
  }
}
