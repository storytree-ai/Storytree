# Copy to .env and fill in. .env is gitignored.

# --- Model provider (Anthropic SDK only — the owned loop runs on the Messages API) ---
ANTHROPIC_API_KEY=

# --- Runtime store: Cloud SQL Postgres, keyless IAM auth (ADR-0021) ---
# No password and no DATABASE_URL: the connector mints short-lived IAM tokens
# from your ambient ADC. DBOS is deferred (ADR-0019), so this is a plain typed
# Postgres connection. These two values are non-secret and usually unnecessary
# (defaults come from gcloud ADC + infra) — set them only to override:
#   STORYTREE_DB_USER=          # your IAM database user (a Google account email)
#   STORYTREE_DB_INSTANCE=      # instance connection name, e.g.
#                               #   storytree-498613:australia-southeast1:storytree-pg
