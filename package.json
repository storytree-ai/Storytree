{
  "name": "storytree",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "An agentic software-builder: a DAG of stories grown by AI coding agents, watched live.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "storytree": "pnpm --filter @storytree/cli storytree --",
    "check:manifest": "node scripts/check-manifest.mjs",
    "check:boundaries": "pnpm --filter @storytree/cli exec node --import tsx src/check-boundaries.ts",
    "build:claude": "pnpm --filter @storytree/cli exec node --import tsx src/build-claude-md.ts",
    "check:claude": "pnpm --filter @storytree/cli exec node --import tsx src/build-claude-md.ts --check",
    "build:agents": "pnpm --filter @storytree/cli exec node --import tsx src/build-agents.ts",
    "check:agents": "pnpm --filter @storytree/cli exec node --import tsx src/build-agents.ts --check",
    "check:agents-sync": "pnpm --filter @storytree/cli exec node --import tsx src/check-agents-sync.ts",
    "check:web-grounding": "pnpm --filter @storytree/cli exec node --import tsx src/check-web-grounding.ts",
    "check:idle-stop": "node --test infra/functions/idle-stop/decide.test.js",
    "gate": "pnpm check:manifest && pnpm check:boundaries && pnpm check:claude && pnpm check:agents && pnpm check:web-grounding && pnpm -r typecheck && pnpm -r test && pnpm check:idle-stop && pnpm check:agents-sync",
    "sync": "git fetch origin && git rebase origin/main",
    "db:up": "pnpm --filter @storytree/cli run db -- up",
    "db:down": "pnpm --filter @storytree/cli run db -- down",
    "db:status": "pnpm --filter @storytree/cli run db -- status",
    "studio:up": "node scripts/studio.mjs up",
    "studio:down": "node scripts/studio.mjs down",
    "studio:status": "node scripts/studio.mjs status"
  }
}
