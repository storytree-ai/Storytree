{
  "name": "storytree",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "An agentic software-builder: a DAG of stories grown by AI coding agents, watched live.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "storytree": "node packages/cli/launch.mjs",
    "check:manifest": "node scripts/check-manifest.mjs",
    "check:boundaries": "pnpm --filter @storytree/cli exec node --import tsx src/check-boundaries.ts",
    "build:claude": "pnpm --filter @storytree/cli exec node --import tsx src/build-claude-md.ts",
    "check:claude": "pnpm --filter @storytree/cli exec node --import tsx src/build-claude-md.ts --check",
    "build:agents": "pnpm --filter @storytree/cli exec node --import tsx src/build-agents.ts",
    "build:status": "pnpm --filter @storytree/cli exec node --import tsx src/build-unit-status.ts",
    "check:agents": "pnpm --filter @storytree/cli exec node --import tsx src/build-agents.ts --check",
    "check:process-graph": "pnpm --filter @storytree/cli exec node --import tsx src/check-process-graph.ts",
    "check:agents-sync": "pnpm --filter @storytree/cli exec node --import tsx src/check-agents-sync.ts",
    "check:corpus-sync": "pnpm --filter @storytree/cli exec node --import tsx src/check-corpus-sync.ts",
    "check:corpus-content": "pnpm --filter @storytree/cli exec node --import tsx src/check-corpus-content.ts",
    "check:friction-drain": "pnpm --filter @storytree/cli exec node --import tsx src/check-friction-drain.ts",
    "check:deploy-health": "pnpm --filter @storytree/cli exec node --import tsx src/check-deploy-health.ts",
    "check:corpus-build": "pnpm --filter studio exec node --import tsx data/build-corpus.mjs --check",
    "check:coverage": "pnpm --filter @storytree/cli exec node --import tsx src/check-coverage.ts",
    "check:surface-coverage": "pnpm --filter @storytree/cli exec node --import tsx src/check-surface-coverage.ts",
    "check:declared": "pnpm --filter @storytree/cli exec node --import tsx src/check-declared.ts",
    "check:graduation-worklist": "pnpm --filter @storytree/cli exec node --import tsx src/check-graduation-worklist.ts",
    "check:web-grounding": "pnpm --filter @storytree/cli exec node --import tsx src/check-web-grounding.ts",
    "sync:web-engine": "pnpm --filter @storytree/cli exec node --import tsx src/web-engine.ts",
    "check:web-engine": "pnpm --filter @storytree/cli exec node --import tsx src/web-engine.ts --check",
    "check:web-experience": "pnpm --filter @storytree/cli exec node --import tsx src/web-experience-check.ts",
    "ci:affected": "pnpm --filter @storytree/cli exec node --import tsx src/ci-affected-main.ts",
    "gate": "pnpm check:manifest && pnpm check:boundaries && pnpm check:claude && pnpm check:agents && pnpm check:process-graph && pnpm check:corpus-build && pnpm check:web-grounding && pnpm check:web-engine && pnpm check:web-experience && pnpm -r typecheck && pnpm -r test && pnpm check:agents-sync && pnpm check:corpus-sync && pnpm check:corpus-content && pnpm check:friction-drain && pnpm check:coverage && pnpm check:surface-coverage && pnpm check:graduation-worklist && pnpm check:declared && pnpm check:deploy-health",
    "sync": "git fetch origin && git rebase origin/main",
    "db:up": "pnpm --filter @storytree/cli run db -- up",
    "db:down": "pnpm --filter @storytree/cli run db -- down",
    "db:status": "pnpm --filter @storytree/cli run db -- status",
    "studio:up": "node scripts/studio.mjs up",
    "studio:down": "node scripts/studio.mjs down",
    "studio:status": "node scripts/studio.mjs status",
    "desktop:start": "pnpm --filter desktop start"
  }
}
